# Copy to .env and fill in the key.
# Without it, the game runs in mock mode with scripted agents and text-only audio.
MISTRAL_API_KEY=

# Production browser admission. When this secret is absent, Turnstile is
# disabled so localhost remains usable. The public site key lives in app/config.py.
TURNSTILE_SECRET_KEY=

# Optional model overrides (defaults live in app/config.py).
# IMPOSTRAL_CHAT_MODEL_LARGE=mistral-large-latest
# IMPOSTRAL_CHAT_MODEL_MEDIUM=mistral-medium-latest
# IMPOSTRAL_CHAT_MODEL_SMALL=mistral-small-latest
# IMPOSTRAL_CHAT_MODEL_MINISTRAL=ministral-8b-latest
# IMPOSTRAL_STT_MODEL=voxtral-mini-latest
# IMPOSTRAL_STT_LANGUAGE=en
# IMPOSTRAL_TTS_MODEL=voxtral-mini-tts-latest
# IMPOSTRAL_TTS_PLAYBACK_RATE=1.1
# IMPOSTRAL_TTS_RETRY_ATTEMPTS=2
# IMPOSTRAL_REVEAL_GAP_SECONDS=0.15
# IMPOSTRAL_HUMAN_WAIT_SECONDS=15
# Public matchmaking only auto-starts once this many humans are present (humans
# can only win with at least two seats), extending the wait a bounded number of
# times before starting a lone player anyway.
# IMPOSTRAL_MIN_PUBLIC_START_HUMANS=2
# IMPOSTRAL_MAX_PUBLIC_START_EXTENSIONS=1

# JSONL game results used by /stats.html.
# IMPOSTRAL_STATS_PATH=data/results.jsonl
